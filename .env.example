# ===========================================
# AIWorld — Variables de Entorno
# ===========================================
# Copia este archivo a .env y configura tus valores.
# Tanto el backend (aifoundry/) como el frontend (hefesto/) leen de aquí.

# ===========================================
# LLM Configuration (LiteLLM)
# ===========================================
LITELLM_API_BASE=https://api.openai.com/v1
LITELLM_API_KEY=your-api-key-here
LITELLM_MODEL=gpt-4.1

# ===========================================
# Default LLM Settings
# ===========================================
DEFAULT_TEMPERATURE=0.1
DEFAULT_MAX_TOKENS=15000
LLM_NUM_RETRIES=3
LLM_REQUEST_TIMEOUT=120

# ===========================================
# MCP Servers Configuration
# ===========================================
BRAVE_SEARCH_MCP_URL=http://localhost:8082/mcp
PLAYWRIGHT_MCP_URL=http://localhost:8931/mcp
BRAVE_API_KEY=your-brave-api-key-here

# ===========================================
# Frontend (Hefesto) — prefijo VITE_ para Vite
# ===========================================
VITE_API_URL=http://localhost:8000/api